{
    "name": "pbarney/text-normalizer",
    "description": "Configurable text normalization package with deterministic and AI-assisted normalization.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client implementation.",
        "nyholm/psr7": "PSR-7 / PSR-17 implementation.",
        "vlucas/phpdotenv": "dotenv support, useful for local development and examples."
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "nyholm/psr7": "^1.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "TextNormalizer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TextNormalizer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}